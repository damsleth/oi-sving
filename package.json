{
  "name": "oisving",
  "version": "2.1.2",
  "description": "Oi, Sving! - HTML5 multiplayer take on Achtung, die Kurve!",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/damsleth/oi-sving/"
  },
  "author": "Oi, Sving! contributors. Forked from Markus Mächler (https://github.com/maechler/kurve)",
  "license": "GPL-3.0",
  "scripts": {
    "clean": "rm -rf dist",
    "build:js": "bun run scripts/build.ts",
    "build:css": "bun x sass scss/main.scss dist/css/main.css --no-source-map --quiet-deps",
    "build:images": "mkdir -p dist/images && cp -R images/. dist/images/",
    "build:sound": "mkdir -p dist/sound && cp -R sound/. dist/sound/",
    "build:manifest": "bun run scripts/generate-asset-manifest.ts",
    "build:signaling": "bun run scripts/compile-signaling.ts",
    "build:signaling:all": "bun run scripts/compile-signaling-all.ts",
    "build:standalone": "bun run build && bun run build:signaling",
    "build:release": "bun run build && bun run build:signaling:all",
    "build": "bun run build:js && bun run build:css && bun run build:images && bun run build:sound && bun run build:manifest",
    "dist": "bun run clean && bun run typecheck && bun run build && bun run test",
    "test:e2e:webrtc": "bun run scripts/e2e-webrtc-smoke.ts",
    "test:e2e:webrtc:long": "bun run scripts/e2e-webrtc-smoke-long.ts",
    "test:smoke:standalone": "bun run scripts/smoke-standalone.ts",
    "release": "bun run dist",
    "typecheck": "bun x tsc --noEmit",
    "pretest": "bun run build",
    "test": "bun test",
    "watch:js": "bun build src/main.ts --outfile=dist/js/oisving.min.js --target=browser --sourcemap=linked --define __DEV__=false --watch",
    "watch:css": "bun x sass scss/main.scss dist/css/main.css --watch --no-source-map --quiet-deps",
    "serve": "bun run server/signaling-server.ts",
    "dev:watch": "bun run scripts/dev.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "sass": "^1.54.5",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "pixi.js": "^6.5.1"
  }
}
